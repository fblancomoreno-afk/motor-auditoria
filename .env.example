# Copia este archivo como .env y rellena tu API key real
# La key NUNCA se expone al navegador — solo vive en el servidor

ANTHROPIC_API_KEY=sk-ant-api03-...

# Conector Google Ads (MCP) — en producción se configuran en
# las Variables del servicio del motor en Railway, nunca en el código
MCP_URL=https://mcp-google-ads-production-7e35.up.railway.app
MCP_API_KEY=...

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
